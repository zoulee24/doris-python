# Apache Doris 数据库连接配置示例
# 使用方法：
#   1. 复制本文件为 .env：   cp .env.example .env
#   2. 修改下面的值为你的真实环境
#   3. 不要把 .env 提交到版本控制（已在 .gitignore 中忽略）

# 登录用户名
DORIS_USER=root

# 登录密码
DORIS_PASSWORD=changeme

# FE 节点地址
DORIS_HOST=127.0.0.1

# FE 查询端口（默认 9030）
DORIS_PORT=9030

# 要连接的数据库名
DORIS_DATABASE=example_db

# SQLAlchemy 方言 + 驱动组合，可选：
#   doris+pymysql     同步（默认）
#   doris+mysqldb     同步
#   doris+aiomysql    异步
#   doris+asyncmy     异步
DORIS_DRIVER=doris+pymysql